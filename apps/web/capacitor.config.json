{
  "appId": "com.mingshoplink.app",
  "appName": "Multi Shop Link",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "url": "",
    "cleartext": true
  },
  "ios": {
    "contentInset": "automatic",
    "preferredContentMode": "mobile",
    "scheme": "Multi Shop Link",
    "limitsNavigationsToAppBoundDomains": true
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "PushNotifications": {
      "presentationOptions": [
        "badge",
        "sound",
        "alert"
      ]
    }
  }
}