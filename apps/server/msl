#!/bin/sh
# MSL Container Management Tool
# Usage: msl

DB="/app/data/store.db"
BACKUP_DIR="/app/backups"
VERSION_FILE="/app/data/version.json"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

show_header() {
  clear
  echo -e "${CYAN}╔══════════════════════════════════════╗${NC}"
  echo -e "${CYAN}║    ${BOLD}多店管理系统 - 容器管理工具${NC}${CYAN}      ║${NC}"
  echo -e "${CYAN}╠══════════════════════════════════════╣${NC}"
  if [ -f "$VERSION_FILE" ]; then
    VER=$(cat "$VERSION_FILE" | tr -d '{}' | sed 's/"version":"//;s/"//')
    echo -e "${CYAN}║  版本: ${GREEN}v${VER}${NC}${CYAN}                       ║${NC}"
  fi
  echo -e "${CYAN}║  节点: $(node --version 2>/dev/null || echo 'N/A')              ║${NC}"
  echo -e "${CYAN}╚══════════════════════════════════════╝${NC}"
  echo ""
}

show_menu() {
  echo -e "${BOLD}请选择操作:${NC}"
  echo ""
  echo -e "  ${GREEN}1${NC}) 系统信息"
  echo -e "  ${GREEN}2${NC}) 备份数据库"
  echo -e "  ${GREEN}3${NC}) 恢复数据库"
  echo -e "  ${GREEN}4${NC}) 重置管理员密码"
  echo -e "  ${GREEN}5${NC}) 查看最近日志"
  echo -e "  ${GREEN}6${NC}) 清理临时文件"
  echo -e "  ${GREEN}7${NC}) 数据库维护"
  echo -e "  ${GREEN}8${NC}) 查看SSE连接"
  echo -e "  ${GREEN}9${NC}) 重启服务"
  echo -e "  ${YELLOW}0${NC}) 退出"
  echo ""
  echo -ne "${CYAN}请输入选择 [0-9]: ${NC}"
}

do_system_info() {
  echo ""
  echo -e "${BOLD}═══ 系统信息 ═══${NC}"
  if [ -f "$VERSION_FILE" ]; then
    VER=$(cat "$VERSION_FILE" | tr -d '{}' | sed 's/"version":"//;s/"//')
    echo -e "  版本:      ${GREEN}v${VER}${NC}"
  fi
  echo -e "  Node:      $(node --version 2>/dev/null)"
  echo -e "  运行时间:  $(ps -o etime= -p 1 2>/dev/null | tr -d ' ')"
  
  if [ -f "$DB" ]; then
    DB_SIZE=$(du -h "$DB" 2>/dev/null | cut -f1)
    echo -e "  数据库:    ${DB_SIZE}"
    echo ""
    echo -e "${BOLD}── 数据统计 ──${NC}"
    sqlite3 "$DB" "SELECT '  用户: ' || COUNT(*) FROM users;" 2>/dev/null
    sqlite3 "$DB" "SELECT '  门店: ' || COUNT(*) FROM stores;" 2>/dev/null
    sqlite3 "$DB" "SELECT '  记账: ' || COUNT(*) FROM entries;" 2>/dev/null
    sqlite3 "$DB" "SELECT '  盘点: ' || COUNT(*) FROM inventory_checks;" 2>/dev/null
    sqlite3 "$DB" "SELECT '  工资: ' || COUNT(*) FROM payroll;" 2>/dev/null
  fi
  
  echo ""
  echo -e "${BOLD}── 备份列表 ──${NC}"
  if [ -d "$BACKUP_DIR" ]; then
    ls -lh "$BACKUP_DIR"/*.zip 2>/dev/null | awk '{print "  " $NF " (" $5 ")"}' || echo "  暂无备份"
  else
    echo "  暂无备份"
  fi
}

do_backup() {
  echo ""
  echo -e "${BOLD}═══ 备份数据库 ═══${NC}"
  mkdir -p "$BACKUP_DIR"
  TIMESTAMP=$(date +%Y%m%d_%H%M%S)
  BACKUP_FILE="$BACKUP_DIR/backup-${TIMESTAMP}.zip"
  
  echo -e "  执行 WAL checkpoint..."
  sqlite3 "$DB" "PRAGMA wal_checkpoint(TRUNCATE);" 2>/dev/null
  
  echo -e "  创建备份..."
  cd /app/data && zip -q "$BACKUP_FILE" store.db store.db-wal store.db-shm 2>/dev/null
  
  if [ -f "$BACKUP_FILE" ]; then
    SIZE=$(du -h "$BACKUP_FILE" | cut -f1)
    echo -e "  ${GREEN}✓ 备份成功: $BACKUP_FILE ($SIZE)${NC}"
  else
    echo -e "  ${RED}✗ 备份失败${NC}"
  fi
}

do_restore() {
  echo ""
  echo -e "${BOLD}═══ 恢复数据库 ═══${NC}"
  if [ ! -d "$BACKUP_DIR" ]; then
    echo -e "  ${RED}没有备份目录${NC}"
    return
  fi
  
  BACKUPS=$(ls "$BACKUP_DIR"/*.zip 2>/dev/null | sort -r)
  if [ -z "$BACKUPS" ]; then
    echo -e "  ${RED}没有可用备份${NC}"
    return
  fi
  
  echo -e "${BOLD}可用备份:${NC}"
  i=1
  echo "$BACKUPS" | while read f; do
    SIZE=$(du -h "$f" | cut -f1)
    echo "  $i) $(basename $f) ($SIZE)"
    i=$((i + 1))
  done
  
  echo ""
  echo -ne "${YELLOW}输入备份序号 (取消请输入 0): ${NC}"
  read choice
  
  if [ "$choice" = "0" ] || [ -z "$choice" ]; then
    echo -e "  已取消"
    return
  fi
  
  BACKUP_FILE=$(echo "$BACKUPS" | sed -n "${choice}p")
  if [ -z "$BACKUP_FILE" ]; then
    echo -e "  ${RED}无效选择${NC}"
    return
  fi
  
  echo -e "  ${YELLOW}⚠ 即将恢复: $(basename $BACKUP_FILE)${NC}"
  echo -ne "${YELLOW}  确认? (y/N): ${NC}"
  read confirm
  if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
    echo -e "  已取消"
    return
  fi
  
  echo -e "  停止数据库写入..."
  sqlite3 "$DB" "PRAGMA wal_checkpoint(TRUNCATE);" 2>/dev/null
  
  echo -e "  恢复文件..."
  cd /app && unzip -o -q "$BACKUP_FILE" -d /app/data/
  
  echo -e "  ${GREEN}✓ 恢复完成，建议重启服务${NC}"
  echo -ne "${YELLOW}  是否立即重启? (y/N): ${NC}"
  read restart
  if [ "$restart" = "y" ] || [ "$restart" = "Y" ]; then
    echo -e "  正在重启..."
    kill -TERM 1
  fi
}

do_reset_admin() {
  echo ""
  echo -e "${BOLD}═══ 重置管理员密码 ═══${NC}"
  echo -ne "${YELLOW}输入新密码 (留空则自动生成): ${NC}"
  read newpwd
  
  if [ -z "$newpwd" ]; then
    newpwd=$(head -c 8 /dev/urandom | od -An -tx1 | tr -d ' \n')
    echo -e "  自动生成密码: ${GREEN}$newpwd${NC}"
  fi
  
  HASH=$(node -e "console.log(require('bcryptjs').hashSync('$newpwd', 10))" 2>/dev/null)
  if [ -z "$HASH" ]; then
    echo -e "  ${RED}密码哈希生成失败${NC}"
    return
  fi
  
  sqlite3 "$DB" "UPDATE users SET password_hash='$HASH', updated_at=datetime('now','localtime') WHERE username='admin';" 2>/dev/null
  echo -e "  ${GREEN}✓ 管理员密码已重置${NC}"
  echo -e "  用户名: ${BOLD}admin${NC}"
  echo -e "  密码:   ${BOLD}$newpwd${NC}"
  echo -e "  ${YELLOW}请妥善保管，建议登录后立即修改${NC}"
}

do_view_logs() {
  echo ""
  echo -e "${BOLD}═══ 最近日志 (最后30条) ═══${NC}"
  docker logs multi-shop-link --tail 30 2>&1 || echo "  无法读取日志"
}

do_cleanup() {
  echo ""
  echo -e "${BOLD}═══ 清理临时文件 ═══${NC}"
  
  count=0
  # Clean extract dirs in uploads
  for d in /app/uploads/extract-*; do
    if [ -d "$d" ]; then
      rm -rf "$d"
      count=$((count + 1))
    fi
  done
  
  # Clean old backups (keep last 20)
  if [ -d "$BACKUP_DIR" ]; then
    cd "$BACKUP_DIR" && ls -t *.zip 2>/dev/null | tail -n +21 | xargs rm -f 2>/dev/null
  fi
  
  # WAL checkpoint
  sqlite3 "$DB" "PRAGMA wal_checkpoint(TRUNCATE);" 2>/dev/null
  
  echo -e "  ${GREEN}✓ 清理完成: 删除 $count 个临时目录${NC}"
}

do_db_maintenance() {
  echo ""
  echo -e "${BOLD}═══ 数据库维护 ═══${NC}"
  
  echo -e "  WAL checkpoint..."
  sqlite3 "$DB" "PRAGMA wal_checkpoint(TRUNCATE);" 2>/dev/null
  
  echo -e "  数据库完整性检查..."
  RESULT=$(sqlite3 "$DB" "PRAGMA integrity_check;" 2>/dev/null)
  if [ "$RESULT" = "ok" ]; then
    echo -e "  ${GREEN}✓ 完整性检查: 通过${NC}"
  else
    echo -e "  ${RED}✗ 完整性检查: $RESULT${NC}"
  fi
  
  echo -e "  数据库压缩 (VACUUM)..."
  sqlite3 "$DB" "VACUUM;" 2>/dev/null
  
  DB_SIZE=$(du -h "$DB" | cut -f1)
  echo -e "  ${GREEN}✓ 维护完成，当前数据库大小: $DB_SIZE${NC}"
}

do_sse_connections() {
  echo ""
  echo -e "${BOLD}═══ SSE 连接状态 ═══${NC}"
  # This is informational - actual SSE state is in memory
  echo -e "  查看运行日志中的连接信息:"
  docker logs multi-shop-link --tail 10 2>&1 | grep -i "sse\|client" || echo "  无连接信息"
}

do_restart() {
  echo ""
  echo -e "${YELLOW}正在重启服务...${NC}"
  kill -TERM 1
  echo -e "  ${GREEN}✓ 发送 SIGTERM 信号，Docker 将自动重启${NC}"
}

# Main loop
show_header
while true; do
  show_menu
  read choice
  case $choice in
    1) do_system_info ;;
    2) do_backup ;;
    3) do_restore ;;
    4) do_reset_admin ;;
    5) do_view_logs ;;
    6) do_cleanup ;;
    7) do_db_maintenance ;;
    8) do_sse_connections ;;
    9) do_restart; exit 0 ;;
    0) echo -e "\n${GREEN}再见!${NC}"; exit 0 ;;
    *) echo -e "${RED}无效选择，请重新输入${NC}" ;;
  esac
  echo ""
  echo -ne "${CYAN}按任意键返回菜单...${NC}"
  read -n 1 -s
  show_header
done